@page "{id:int}"
@model noithat_ducanh.Pages.NewsDetailModel
@{
    ViewData["Title"] = $"{Model.Post.Title} - Tin Tức - Nội Thất Đức Anh";
    
    var cleanSummary = Model.Post.Summary ?? "";
    if (cleanSummary.Length > 150) {
        cleanSummary = cleanSummary.Substring(0, 147) + "...";
    }
    ViewData["Description"] = cleanSummary;
}

<div class="wrap" style="max-width: 1200px; margin: auto; padding: 40px 24px; min-height: 80vh;">
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" style="margin-bottom: 24px; font-size: 14px; color: var(--color-muted);">
        <a href="/" style="color: var(--color-primary); text-decoration: none; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-primary)'">Trang chủ</a>
        <span style="margin: 0 8px;">/</span>
        <a href="/News" style="color: var(--color-primary); text-decoration: none; font-weight: 500; transition: color 0.2s;" onmouseover="this.style.color='var(--color-accent)'" onmouseout="this.style.color='var(--color-primary)'">Tin tức</a>
        <span style="margin: 0 8px;">/</span>
        <span style="color: var(--color-text);">Chi tiết bài viết</span>
    </nav>

    <!-- Main Grid -->
    <div class="news-detail-grid @(Model.RecentPosts.Any() ? "has-sidebar" : "")" style="display: grid; gap: 40px; align-items: start;">
        <!-- Main Content -->
        <article style="background-color: var(--color-surface); border: 1.5px solid var(--color-border); border-radius: var(--radius-card); padding: 32px; box-shadow: var(--shadow-card);">
            <!-- Title -->
            <h1 style="font-size: 28px; font-weight: 800; color: var(--color-primary-dark); line-height: 1.4; margin-bottom: 16px;">
                @Model.Post.Title
            </h1>

            <!-- Metadata -->
            <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 24px; font-size: 13.5px; color: var(--color-muted); border-bottom: 1.5px solid var(--color-border); padding-bottom: 16px;">
                <span style="display: flex; align-items: center; gap: 6px;">
                    <svg viewBox="0 0 24 24" aria-hidden="true" style="width:14px; height:14px; fill:var(--color-primary);"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke="currentColor" stroke-width="2" fill="none"/></svg> 
                    Đăng ngày: @Model.Post.CreatedAt.ToString("dd/MM/yyyy")
                </span>
                <span style="display: flex; align-items: center; gap: 6px;">
                    <svg viewBox="0 0 24 24" aria-hidden="true" style="width:14px; height:14px; fill:none; stroke:var(--color-primary); stroke-width:2;"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg> 
                    Tác giả: Nội Thất Đức Anh
                </span>
            </div>

            <!-- Feature Image -->
            <div style="border-radius: var(--radius-image); overflow: hidden; margin-bottom: 24px; aspect-ratio: 16/9; max-height: 450px;">
                <img src="@Model.Post.ImageUrl" alt="Hình ảnh minh họa cho bài viết: @Model.Post.Title" onerror="this.src='https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=800&q=80'" style="width: 100%; height: 100%; object-fit: cover;" />
            </div>

            <!-- Summary Blockquote -->
            <div style="background-color: var(--color-background); border-left: 4px solid var(--color-accent); border-radius: 4px; padding: 16px 20px; margin-bottom: 24px; font-style: italic; font-weight: 500; color: var(--color-text); line-height: 1.6;">
                @Model.Post.Summary
            </div>

            <!-- Main Text Content -->
            <div style="white-space: pre-line; line-height: 1.8; color: var(--color-text); font-size: 16px;">
                @Model.Post.Content
            </div>

            <!-- Footer Action -->
            <div style="margin-top: 40px; border-top: 1.5px solid var(--color-border); padding-top: 24px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 16px;">
                <a class="btn-news-back" href="/News" style="display: inline-flex; align-items: center; gap: 8px; color: var(--color-primary); font-weight: 700; text-decoration: none; font-size: 14.5px; transition: transform 0.2s;" onmouseover="this.style.transform='translateX(-4px)'" onmouseout="this.style.transform='translateX(0)'">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true" style="width: 16px; height: 16px;"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
                    Quay lại danh sách tin tức
                </a>

                <div style="display: flex; align-items: center; gap: 12px;">
                    <span style="font-size: 13.5px; color: var(--color-muted); font-weight: 600;">Chia sẻ bài viết:</span>
                    <a href="#" aria-label="Chia sẻ qua Facebook" style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--color-background); display: inline-flex; align-items: center; justify-content: center; color: var(--color-primary); transition: background-color 0.2s, color 0.2s;" onmouseover="this.style.backgroundColor='var(--color-primary)'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='var(--color-background)'; this.style.color='var(--color-primary)';" title="Chia sẻ Facebook">
                        <svg viewBox="0 0 24 24" aria-hidden="true" style="width: 16px; height: 16px; fill: currentColor;"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                    </a>
                    <a href="https://zalo.me" target="_blank" aria-label="Chia sẻ qua Zalo" style="width: 32px; height: 32px; border-radius: 50%; background-color: var(--color-background); display: inline-flex; align-items: center; justify-content: center; color: var(--color-primary); transition: background-color 0.2s, color 0.2s;" onmouseover="this.style.backgroundColor='var(--color-primary)'; this.style.color='#fff';" onmouseout="this.style.backgroundColor='var(--color-background)'; this.style.color='var(--color-primary)';" title="Chia sẻ Zalo">
                        <svg viewBox="0 0 24 24" aria-hidden="true" style="width: 16px; height: 16px; fill: currentColor;"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/><text x="7.5" y="15.5" font-size="9" fill="currentColor" font-weight="bold" font-family="Arial">Z</text></svg>
                    </a>
                </div>
            </div>
        </article>

        <!-- Sidebar Recent Posts -->
        @if (Model.RecentPosts.Any())
        {
            <aside style="display: flex; flex-direction: column; gap: 24px;">
                <div style="background-color: var(--color-surface); border: 1.5px solid var(--color-border); border-radius: var(--radius-card); padding: 24px; box-shadow: var(--shadow-card);">
                    <h2 style="font-size: 18px; font-weight: 800; color: var(--color-primary-dark); margin-bottom: 20px; border-bottom: 2px solid var(--color-accent); padding-bottom: 10px; display: inline-block;">
                        Bài viết mới nhất
                    </h2>
                    <div style="display: flex; flex-direction: column; gap: 20px;">
                        @foreach (var p in Model.RecentPosts)
                        {
                            <a href="/NewsDetail/@p.Id" style="display: flex; gap: 12px; text-decoration: none; transition: transform 0.2s;" onmouseover="this.style.transform='translateX(4px)';" onmouseout="this.style.transform='translateX(0)';">
                                <div style="width: 70px; height: 70px; border-radius: 8px; overflow: hidden; flex-shrink: 0;">
                                    <img src="@p.ImageUrl" alt="@p.Title" onerror="this.src='https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=150&q=80'" style="width: 100%; height: 100%; object-fit: cover;" />
                                </div>
                                <div style="display: flex; flex-direction: column; justify-content: center;">
                                    <h3 style="font-size: 13.5px; font-weight: 700; color: var(--color-text); line-height: 1.4; margin-bottom: 6px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; transition: color 0.2s;" onmouseover="this.style.color='var(--color-primary)';" onmouseout="this.style.color='var(--color-text)';">
                                        @p.Title
                                    </h3>
                                    <span style="font-size: 11.5px; color: var(--color-muted); display: flex; align-items: center; gap: 4px;">
                                        <svg viewBox="0 0 24 24" aria-hidden="true" style="width:11px; height:11px; fill:var(--color-accent);"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke="currentColor" stroke-width="2" fill="none"/></svg> 
                                        @p.CreatedAt.ToString("dd/MM/yyyy")
                                    </span>
                                </div>
                            </a>
                        }
                    </div>
                </div>

                <!-- Banner Hỗ Trợ Tư Vấn -->
                <div style="background-color: var(--color-primary-dark); color: #fff; border-radius: var(--radius-card); padding: 24px; text-align: center; box-shadow: var(--shadow-card); position: relative; overflow: hidden;">
                    <div style="position: absolute; top: -20px; right: -20px; width: 80px; height: 80px; background-color: var(--color-accent); opacity: 0.15; border-radius: 50%;"></div>
                    <div style="position: absolute; bottom: -30px; left: -30px; width: 120px; height: 120px; background-color: var(--color-accent); opacity: 0.1; border-radius: 50%;"></div>
                    
                    <h3 style="font-size: 18px; font-weight: 800; color: var(--color-accent); margin-bottom: 12px;">Tư Vấn Thiết Kế Miễn Phí</h3>
                    <p style="font-size: 13px; line-height: 1.6; opacity: 0.9; margin-bottom: 20px;">Đội ngũ kiến trúc sư Đức Anh sẵn sàng hỗ trợ bạn đo đạc, lên bản vẽ 3D và báo giá miễn phí tại nhà.</p>
                    <a href="/Contact" style="display: inline-block; background-color: var(--color-accent); color: var(--color-text); font-weight: 800; font-size: 13.5px; padding: 10px 24px; border-radius: var(--radius-button); text-decoration: none; transition: transform 0.2s, background-color 0.2s;" onmouseover="this.style.transform='scale(1.05)'; this.style.backgroundColor='var(--color-accent-light)';" onmouseout="this.style.transform='scale(1)'; this.style.backgroundColor='var(--color-accent)';">
                        Gửi yêu cầu ngay
                    </a>
                </div>
            </aside>
        }
    </div>
</div>

<style>
    .news-detail-grid {
        grid-template-columns: 1fr;
    }
    
    @@media (min-width: 992px) {
        .news-detail-grid.has-sidebar {
            grid-template-columns: 2.3fr 1fr;
        }
    }
</style>
