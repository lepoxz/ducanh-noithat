@page
@model noithat_ducanh.Pages.NewsModel
@{
    ViewData["Title"] = "Tin Tức & Bài Viết - Nội Thất Đức Anh";
    ViewData["Description"] = "Cập nhật các tin tức mới nhất, mẹo thiết kế nội thất đẹp, cẩm nang chọn mua tủ nhựa Đài Loan, tủ bếp Ecoplast từ xưởng Nội Thất Đức Anh.";
}

<section class="sec" style="min-height: 80vh; padding-top: 40px;">
    <!-- Section Header -->
    <div class="sec-hd" style="margin-bottom: 30px;">
        <div>
            <h2 class="sec-title" style="font-size: 26px;">Tin Tức & Cẩm Nang</h2>
            <p style="color: var(--color-muted); margin-top: 6px; font-size: 14.5px;">Chia sẻ kinh nghiệm thiết kế, lựa chọn nội thất nhựa đẹp, bền bỉ và hiện đại cho ngôi nhà của bạn</p>
        </div>
    </div>

    <!-- News Grid -->
    <div class="news-grid" style="grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px;">
        @if (Model.Posts.Any())
        {
            @foreach (var post in Model.Posts)
            {
                <div class="ncard">
                    <img src="@post.ImageUrl" alt="Ảnh minh họa bài viết: @post.Title" onerror="this.src='https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=500&q=80'" />
                    <div class="ni">
                        <div class="ndate">
                            <svg viewBox="0 0 24 24" aria-hidden="true" style="width:13px; height:13px; fill:var(--color-accent);"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke="currentColor" stroke-width="2" fill="none"/></svg> 
                            @post.CreatedAt.ToString("dd/MM/yyyy")
                        </div>
                        <h3 style="font-size: 15px; font-weight: 800; color: var(--color-text); margin-bottom: 10px; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @post.Title
                        </h3>
                        <p style="font-size: 13.5px; color: var(--color-muted); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 16px; line-height: 1.6;">
                            @post.Summary
                        </p>
                        <a class="nmore" href="/NewsDetail/@post.Id" style="text-decoration: none;">Đọc tiếp <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
                    </div>
                </div>
            }
        }
        else
        {
            <div style="grid-column: 1 / -1; background-color: var(--color-surface); border: 1.5px solid var(--color-border); border-radius: var(--radius-card); padding: 40px; text-align: center; color: var(--color-muted); box-shadow: var(--shadow-card);">
                <p style="font-size: 15px;">Hiện tại chưa có bài viết nào được đăng tải.</p>
            </div>
        }
    </div>
</section>
