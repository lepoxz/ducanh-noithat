        <div class="pjcard" onclick="location.href='/Projects'">
          <img src="https://noithathaiminh.com.vn/uploads/project/du-an-noi-that-nhua-chung-cu-cho-khach-hang-o-phuong-phu-dien-ha-noi.jpg" alt="Dự án hoàn thiện lắp ráp nội thất nhựa tại Phú Diễn – Hà Nội" onerror="this.src='https://images.unsplash.com/photo-1555041469-a586c61ea9bc?w=500&q=80'"/>
          <div class="pjover">
            <span>Dự Án Chung Cư Phú Diễn – Hà Nội</span>
          </div>
        </div>
        <div class="pjcard" onclick="location.href='/Projects'">
          <img src="https://noithathaiminh.com.vn/uploads/project/du-an-noi-that-nhua-chung-cu-cho-khach-hang-o-hoan-kiem-ha-noi.jpg" alt="Dự án nội thất căn hộ gia đình sang trọng tại quận Hoàn Kiếm – Hà Nội" onerror="this.src='https://images.unsplash.com/photo-1631049307264-da0ec9d70304?w=500&q=80'"/>
          <div class="pjover">
            <span>Dự Án Chung Cư Hoàn Kiếm – Hà Nội</span>
          </div>
        </div>
        <div class="pjcard" onclick="location.href='/Projects'">
          <img src="https://noithathaiminh.com.vn/uploads/project/du-an-noi-that-nhua-sieu-sang-cho-khach-hang-o-hoang-mai-ha-noi.jpg" alt="Không gian phòng khách nội thất cao cấp tại Hoàng Mai – Hà Nội" onerror="this.src='https://images.unsplash.com/photo-1616594039964-ae9021a400a0?w=500&q=80'"/>
          <div class="pjover">
            <span>Dự Án Nội Thất Siêu Sang Hoàng Mai – Hà Nội</span>
          </div>
        </div>
    }
  </div>
</section>

<!-- NEWS -->
<section class="sec" id="tin-tuc">
  <div class="sec-hd">
    <h2 class="sec-title">Tin Tức & Bài Viết</h2>
  </div>
  <div class="news-grid">
    @foreach (var post in Model.Posts)
    {
        <div class="ncard">
          <img src="@post.ImageUrl" alt="Ảnh minh họa bài viết: @post.Title" onerror="this.src='https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=500&q=80'"/>
          <div class="ni">
            <div class="ndate"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke="currentColor" stroke-width="2" fill="none"/></svg> @post.CreatedAt.ToString("dd/MM/yyyy")</div>
            <h3>@post.Title</h3>
            <p>@post.Summary</p>
            <a class="nmore" href="/NewsDetail/@post.Id">Đọc tiếp <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg></a>
          </div>
        </div>
    }
  </div>
</section>

<!-- CTA BANNER / CONSULTATION FORM -->
<div class="cta-banner" id="tu-van">
  <div class="cta-info">
    <span class="cta-badge">🎁 Ưu đãi đặc biệt</span>
    <h2 class="cta-title">Tư Vấn Thiết Kế <span class="highlight">Miễn Phí</span> Tận Nơi!</h2>
    <p class="cta-desc">Đội ngũ chuyên gia từ xưởng Đức Anh sẵn sàng đến tận nhà khảo sát, đo đạc kích thước và báo giá hoàn toàn miễn phí cho bạn.</p>
    
    <ul class="cta-features">
      <li>
        <span class="feat-icon">✓</span>
        <div class="feat-text">
          <strong>Đo đạc & khảo sát trực tiếp</strong>
          <span>Chúng tôi khảo sát không gian thực tế để thiết kế tối ưu nhất.</span>
        </div>
      </li>
      <li>
        <span class="feat-icon">✓</span>
        <div class="feat-text">
          <strong>Thiết kế phối cảnh 3D miễn phí</strong>
          <span>Xem bản vẽ chân thực không gian nội thất của bạn trước khi sản xuất.</span>
        </div>
      </li>
      <li>
        <span class="feat-icon">✓</span>
        <div class="feat-text">
          <strong>Cam kết chống nước & mối mọt 100%</strong>
          <span>Nhựa cao cấp nhập khẩu có tuổi thọ vượt trội so với gỗ công nghiệp.</span>
        </div>
      </li>
    </ul>
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="cta-success-msg" aria-live="polite">
            <span class="success-icon">✔</span>
            <span>@TempData["SuccessMessage"]</span>
        </div>
    }
  </div>
  
  <div class="cta-btns">
    <form method="post" class="cta-form">
      @Html.AntiForgeryToken()
      
      <div class="cta-form-header">
        <h3 class="cta-form-title">Đăng Ký Tư Vấn</h3>
        <p class="cta-form-subtitle">Điền thông tin bên dưới để xưởng liên hệ lại ngay</p>
      </div>

      <div asp-validation-summary="All" class="validation-summary-errors" aria-live="polite"></div>
      
      <div class="cta-form-group">
        <label for="contact_fullname">Họ và tên của bạn *</label>
        <input type="text" id="contact_fullname" asp-for="Contact.FullName" placeholder="Ví dụ: Nguyễn Văn A…" required class="cta-form-input" />
      </div>

      <div class="cta-form-group">
        <label for="contact_phone">Số điện thoại liên hệ *</label>
        <input type="tel" id="contact_phone" asp-for="Contact.PhoneNumber" placeholder="Ví dụ: 0773121234…" required class="cta-form-input" />
      </div>

      <div class="cta-form-group">
        <label for="contact_address">Địa chỉ lắp đặt (nếu có)</label>
        <input type="text" id="contact_address" asp-for="Contact.Address" placeholder="Ví dụ: Ông Bầu, Tỉnh Đồng Tháp…" class="cta-form-input" />
      </div>

      <div class="cta-form-group">
        <label for="contact_message">Nội dung cần tư vấn</label>
        <textarea id="contact_message" asp-for="Contact.Message" placeholder="Ví dụ: Tôi cần tư vấn tủ bếp và tủ quần áo nhựa Ecoplast…" rows="2" class="cta-form-input" style="resize: vertical;"></textarea>
      </div>
      
      <button type="submit" class="cta-form-btn">GỬI YÊU CẦU NGAY</button>
    </form>
  </div>
</div>
