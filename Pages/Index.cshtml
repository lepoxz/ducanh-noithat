            <a href="/ProjectDetail/@project.Id" class="pjcard" style="display: block; text-decoration: none;">
              <img src="@project.ImageUrl" alt="Dự án thi công: @project.Title" onerror="this.src='https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=500&q=80'"/>
