@page
@model noithat_ducanh.Pages.Admin.ManageSocialLinksModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Liên Kết MXH";
}

<div class="admin-split-layout">
    
    <!-- LEFT PANEL: FORM SECTION -->
    <div class="content-card">
        <div class="card-header">
            <h3 class="card-title">
                @(Model.IsEditMode ? "✍ Sửa Liên Kết MXH" : "➕ Thêm Liên Kết Mới")
            </h3>
        </div>
        
        <form method="post" asp-route-editId="@(Model.IsEditMode ? Model.InputSocialLink.Id : null)" style="display: flex; flex-direction: column; gap: 16px;">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="InputSocialLink.Id" />
            
            <div class="form-group">
                <label class="form-label">Chọn mẫu mạng xã hội nhanh</label>
                <select id="preset-selector" class="form-control" style="background-color: #ffffff;">
                    <option value="">-- Chọn mẫu (Tự động điền Icon) --</option>
                    <option value="Facebook">Facebook</option>
                    <option value="Zalo">Zalo</option>
                    <option value="YouTube">YouTube</option>
                    <option value="TikTok">TikTok</option>
                    <option value="Instagram">Instagram</option>
                    <option value="Twitter/X">Twitter/X</option>
                </select>
            </div>

            <div class="form-group">
                <label class="form-label">Tên mạng xã hội *</label>
                <input type="text" asp-for="InputSocialLink.Name" id="social-name" required class="form-control" placeholder="Ví dụ: Facebook, Zalo, YouTube..." />
            </div>

            <div class="form-group">
                <label class="form-label">Đường dẫn liên kết (URL) *</label>
                <input type="text" asp-for="InputSocialLink.Url" required class="form-control" placeholder="Ví dụ: https://facebook.com/..." />
            </div>

            <div class="form-group">
                <label class="form-label">Thứ tự hiển thị</label>
                <input type="number" asp-for="InputSocialLink.Order" class="form-control" placeholder="Số nhỏ hơn hiển thị trước..." />
            </div>

            <div class="form-group">
                <label class="form-label">Mã biểu tượng SVG *</label>
                <textarea asp-for="InputSocialLink.Icon" id="social-icon" rows="6" required class="form-control" style="resize: vertical; font-family: monospace; font-size: 12.5px;" placeholder="Dán mã <svg>...</svg> của mạng xã hội vào đây..."></textarea>
            </div>

            <label class="checkbox-group" for="IsActiveCheck">
                <input type="checkbox" asp-for="InputSocialLink.IsActive" id="IsActiveCheck" class="checkbox-control" />
                <span class="form-label" style="font-weight: 600; cursor: pointer; user-select: none;">Kích hoạt hiển thị</span>
            </label>

            <div style="display: flex; gap: 10px; margin-top: 10px;">
                <button type="submit" class="btn-admin btn-admin-primary" style="flex: 1; padding: 11px 20px;">
                    @(Model.IsEditMode ? "Cập Nhật" : "Thêm Mới")
                </button>
                @if (Model.IsEditMode)
                {
                    <a href="/Admin/ManageSocialLinks" class="btn-admin btn-admin-secondary" style="padding: 11px 20px; text-align: center;">Hủy sửa</a>
                }
            </div>
        </form>
    </div>

    <!-- RIGHT PANEL: LIST SECTION -->
    <div class="content-card">
        <div class="card-header">
            <h3 class="card-title">🌐 Mạng Xã Hội Đang Liên Kết (@Model.SocialLinks.Count)</h3>
        </div>
        
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th style="width: 50px;">Icon</th>
                        <th>Tên MXH</th>
                        <th>Đường dẫn liên kết</th>
                        <th>Thứ tự</th>
                        <th>Trạng thái</th>
                        <th style="text-align: right; width: 130px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.SocialLinks.Any())
                    {
                        @foreach (var s in Model.SocialLinks)
                        {
                            <tr>
                                <td>
                                    <div style="width: 28px; height: 28px; display: flex; align-items: center; justify-content: center; fill: var(--admin-primary); color: var(--admin-primary);">
                                        @Html.Raw(s.Icon)
                                    </div>
                                </td>
                                <td style="font-weight: 700; color: var(--admin-text-main);">
                                    @s.Name
                                </td>
                                <td style="font-size: 13px; max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                    <a href="@s.Url" target="_blank" style="color: var(--admin-primary); text-decoration: underline;">@s.Url</a>
                                </td>
                                <td style="font-weight: 600;">
                                    @s.Order
                                </td>
                                <td>
                                    @if (s.IsActive)
                                    {
                                        <span class="badge badge-success">✓ Hiện</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-warning">✕ Ẩn</span>
                                    }
                                </td>
                                <td style="text-align: right; white-space: nowrap;">
                                    <div class="btn-group">
                                        <a href="/Admin/ManageSocialLinks?editId=@s.Id" class="btn-admin btn-admin-secondary btn-admin-sm">Sửa</a>
                                        
                                        <form method="post" asp-page-handler="Delete" asp-route-id="@s.Id" style="display: inline;" confirm-title="Xóa liên kết" confirm-message="Bạn có chắc chắn muốn xóa liên kết mạng xã hội này?">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-admin btn-admin-danger btn-admin-sm">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" style="text-align: center; padding: 40px; color: var(--admin-text-muted);">
                                Chưa có mạng xã hội nào được cấu hình.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    
</div>

@section Scripts {
    <script>
        const presets = {
            "Facebook": '<svg viewBox="0 0 24 24" aria-hidden="true" style="width:100%;height:100%;"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>',
            "Zalo": '<svg viewBox="0 0 24 24" aria-hidden="true" style="width:100%;height:100%;"><circle cx="12" cy="12" r="10" fill="#0068ff"/><text x="7.5" y="16.5" font-size="9" fill="white" font-weight="bold" font-family="Arial">Z</text></svg>',
            "YouTube": '<svg viewBox="0 0 24 24" aria-hidden="true" style="width:100%;height:100%;"><path d="M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 001.46 6.42 29 29 0 001 12a29 29 0 00.46 5.58 2.78 2.78 0 001.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.96A29 29 0 0023 12a29 29 0 00-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg>',
            "TikTok": '<svg viewBox="0 0 24 24" aria-hidden="true" style="width:100%;height:100%;"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.28 6.28 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.15 8.15 0 004.77 1.52V6.77a4.85 4.85 0 01-1-.08z" fill="white"/></svg>',
            "Instagram": '<svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:100%;height:100%;"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>',
            "Twitter/X": '<svg viewBox="0 0 24 24" aria-hidden="true" style="width:100%;height:100%;"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>'
        };

        document.getElementById('preset-selector').addEventListener('change', function() {
            const val = this.value;
            if (val && presets[val]) {
                document.getElementById('social-name').value = val;
                document.getElementById('social-icon').value = presets[val];
            }
        });
    </script>
}
